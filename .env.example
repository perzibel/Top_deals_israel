# Run mode
DRY_RUN=false
POST_INTERVAL_MINUTES=180
MAX_POSTS_PER_RUN=3
POSTS_PER_BATCH=3

# AliExpress - fill after approval
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=telegram_main
ALIEXPRESS_API_ENDPOINT=https://api-sg.aliexpress.com/sync
ALIEXPRESS_SEARCH_METHOD=aliexpress.affiliate.product.query
ALIEXPRESS_LINK_METHOD=aliexpress.affiliate.link.generate

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=-1003933451978

# Ollama - optional, if empty the engine uses basic text templates
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
USE_OLLAMA=true
SOCIAL_MODEL=qwen3:14b
OLLAMA_HOST=http://localhost:11434

# Deal filters
MIN_RATING=4.4
MIN_ORDERS=1000
MAX_PRICE_USD=80
MIN_DISCOUNT_PERCENT=5

KEYWORDS='Security camera,superdeals,portabel charger,lego ,gaming, keyboard,car vacuum cleaner,portable tire inflator,dash cam,wireless charger,car sun shade,pet hair remover,dog water bottle,pet grooming brush,automatic pet feeder,pet drinking fountain,kitchen organizer,drawer organizer,air fryer accessories,oil spray bottle,vegetable chopper,spice rack,sink organizer,bathroom organizer,closet organizer,vacuum storage bags,baby night light,baby stroller organizer,baby car mirror,baby safety lock,stroller fan,baby silicone bib,makeup organizer,led makeup mirror,electric hair trimmer,beard trimmer,travel makeup bag,manicure set,mini vacuum cleaner,electric cleaning brush,lint remover,keyboard cleaning kit,microfiber cloth,monitor light bar,laptop stand,cable organizer,desk lamp,desk mat,vertical mouse,travel organizer,packing cubes,travel adapter,luggage scale,passport holder,100w usb c cable,65w gan charger,100w gan charger,power bank,baseus power bank,ugreen charger,magsafe car holder,smart plug,zigbee sensor,security camera,led strip,aqara temperature sensor,mechanical keyboard,ps5 accessories,electric screwdriver,precision screwdriver set,laser level'
